# cdGTS 환경변수 예시. 복사해서 .env 로 쓰세요:  cp .env.example .env
# .env 는 git 에 커밋되지 않습니다.

# 운영에선 반드시 고유 값으로 재정의. dev 는 settings.py 기본값으로도 동작.
SECRET_KEY=change-me-in-production

# dev=True, 운영=False
DEBUG=True

# 쉼표 구분
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite 경로 (기본: 프로젝트 루트 db.sqlite3)
# DATABASE_PATH=
