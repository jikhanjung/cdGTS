# /srv/cdGTS/.env 템플릿. 복사해서 편집:  cp deploy/host/.env.example /srv/cdGTS/.env
# compose 가 ${IMAGE_TAG} 보간 + 컨테이너 env 로 주입(env_file).

# deploy.sh 가 갱신. 최초엔 배포할 버전으로.
IMAGE_TAG=0.1.0

# 운영: 반드시 고유 값으로. (openssl rand -base64 48)
SECRET_KEY=change-me-in-production

# 운영은 False
DEBUG=False

# 서비스 도메인 + 로컬 헬스체크. 쉼표 구분.
ALLOWED_HOSTS=cdgts.example.org,127.0.0.1,localhost

# 컨테이너 내부 경로 (compose 볼륨과 일치). WAL 공유를 위해 /srv/cdGTS/db 디렉터리를
# /app/hostdb 로 마운트 → DB 는 /app/hostdb/db.sqlite3 (host /srv/cdGTS/db/db.sqlite3, 0.1.64~).
DATABASE_PATH=/app/hostdb/db.sqlite3

# gunicorn 워커 수
GUNICORN_WORKERS=2

# HTTPS(리버스 프록시 뒤) — 도메인/인증서 준비 후 True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
# CSRF_TRUSTED_ORIGINS=https://cdgts.example.org
